PORT=5000
NODE_ENV=production

# CORS for frontend deployment
FRONTEND_URL=https://your-frontend-app.vercel.app
# Optional for multiple domains/previews
# FRONTEND_URLS=https://your-frontend-app.vercel.app,https://staging-frontend.vercel.app
# ALLOW_VERCEL_PREVIEWS=true

# Database (choose one approach)
# DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DB_NAME
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Optional SSL for managed MySQL
# DB_SSL=true
# DB_SSL_CA=

# Auth / Admin / AI
AUTH_SECRET=change-me
ADMIN_API_KEY=change-me
GEMINI_API_KEY=
GEMINI_TIMEOUT_MS=45000
